# ============================================================
# 瓮听声学系统 - 环境变量示例 (复制为 .env 使用)
# ============================================================

# ---------- 通用 ----------
TZ=Asia/Shanghai
COMPOSE_PROJECT_NAME=urn-acoustics

# ---------- Rust 后端 ----------
URN_SERVER__HOST=0.0.0.0
URN_SERVER__PORT=8080
URN_SERVER__STATIC_DIR=/app/static
RUST_LOG=urn_acoustics_backend=info,tower_http=info,axum=info,clickhouse=warn

# ---------- ClickHouse ----------
CLICKHOUSE_VERSION=24.3-alpine
URN_CLICKHOUSE__URL=tcp://clickhouse:9000
URN_CLICKHOUSE__DATABASE=urn_acoustics
URN_CLICKHOUSE__USER=default
URN_CLICKHOUSE__PASSWORD=

# ---------- Mosquitto MQTT ----------
MQTT_BROKER=mosquitto
MQTT_PORT=1883
URN_MQTT__BROKER=mosquitto
URN_MQTT__PORT=1883
URN_MQTT__TOPIC=urn/sensors/#
URN_MQTT__CLIENT_ID=urn-backend-docker
URN_MQTT__KEEP_ALIVE=60

# ---------- 传感器模拟器 ----------
# 介质: dry_sand | wet_sand | clay | limestone | granite
SIM_MEDIUM=wet_sand
# 声源距离 (设置后随机方位，留空则使用 SIM_SOURCE_X / Y)
SIM_SOURCE_DISTANCE=120
SIM_SOURCE_X=100
SIM_SOURCE_Y=0
SIM_SOURCE_Z=-2
SIM_STRENGTH_DB=140
SIM_FREQUENCY=220
SIM_INTERVAL=1.0
# 故意频率漂移百分比 (>5% 触发 warning, >10% critical)
SIM_DRIFT=0
SIM_NOISE=2.0

# ---------- Prometheus (可选 monitoring profile) ----------
PROMETHEUS_VERSION=v2.52.0
